# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Data providers
# Optional but recommended: without it, quotes/news fall back to Yahoo, and
# fundamentals/financial-statement data (/fundamentals, and the fundamentals
# section in /check and /recommend) is unavailable entirely — Yahoo has no
# usable equivalent (its fundamentals endpoint requires a crumb/cookie
# handshake we don't implement). Leave this line blank/unset if you don't
# have a key — do NOT leave a placeholder string here, a non-empty value is
# treated as "configured" even if invalid.
FINNHUB_API_KEY=your_finnhub_key_here

# LLM
# Uses your Claude Pro/Max subscription via the local `claude` CLI login
# instead of a billed API key. Run `claude` once on this machine and sign in
# before starting the bot; no ANTHROPIC_API_KEY is needed (and must NOT be
# set here or in your shell env, or the ACP agent will bill your API account
# instead of using the subscription). Requires Node.js (npx) to be installed.
# Model aliases: "opus", "sonnet", "haiku", or a full model ID. Leave unset
# to use the agent's own default.
CLAUDE_RECOMMEND_MODEL=opus
CLAUDE_CHECK_MODEL=sonnet
CLAUDE_CHAT_MODEL=sonnet
# Optional: point at a globally-installed `claude-agent-acp` binary instead
# of paying npx's resolution overhead on every call:
#   npm install -g @agentclientprotocol/claude-agent-acp
# CLAUDE_ACP_COMMAND=claude-agent-acp

# Storage
DB_PATH=data/argus.db

# Language
# "zh" (Traditional Chinese, default) or "en". Controls both the bot's own
# UI copy (internal/i18n) and the language Claude is asked to answer in for
# /check, /recommend, and chat. Anything unrecognized (including unset)
# falls back to "zh".
BOT_LANGUAGE=zh
